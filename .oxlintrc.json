{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["unicorn", "import", "promise", "node"],
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "warn"
  },
  "env": {
    "es2024": true,
    "node": true,
    "browser": true
  },
  "rules": {
    "unicorn/prefer-type-error": "off",
    "unicorn/consistent-function-scoping": "off",
    "no-underscore-dangle": "off",
    "no-shadow": "off",
    "no-console": "off",
    "no-empty": "error",
    "no-debugger": "error",
    "import/no-named-as-default": "off",
    "import/no-named-as-default-member": "off"
  },
  "ignorePatterns": [
    "src/renderer/eleventy/templates/**/*.js",
    "test/fixtures/**",
    "test/templates/**",
    "test-output",
    "dist",
    "node_modules",
    "coverage"
  ]
}
