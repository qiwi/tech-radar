{
  "name": "@qiwi/tech-radar",
  "description": "Fully automated tech-radar generator",
  "version": "2.0.0",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "exit 0",
    "test": "npm-run-all -p -l lint test:unit test:depcheck",
    "test:unit": "vitest run --coverage",
    "test:depcheck": "npm_config_yes=true npx -p depcheck depcheck --ignores espree",
    "docs": "jsdoc -d dist/docs src/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "generate": "npm run gen:zalando && npm run gen:aurora && npm run gen:redirects && touch dist/.nojekyll",
    "gen:zalando": "node ./src/cli.mjs --renderer zalando --input \"data/**/*.{csv,json,yml}\" --output dist/v1 --base-prefix tech-radar/v1 --autoscope true --nav-page true",
    "gen:aurora": "node ./src/cli.mjs --renderer aurora --input \"data/**/*.{csv,json,yml}\" --output dist/v2 --autoscope true --about data/about.md",
    "gen:redirects": "node scripts/redirects.mjs",
    "preview": "node src/preview",
    "postupdate": "npm install && npm audit fix && npm test && npm run generate"
  },
  "prettier": "prettier-config-qiwi",
  "exports": {
    "types": "./src/index.d.ts",
    "import": "./src/index.js"
  },
  "bin": {
    "techradar": "src/cli.mjs"
  },
  "devDependencies": {
    "@qiwi/npm-run-all": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.5",
    "finalhandler": "^2.1.1",
    "jsdoc": "^4.0.5",
    "oxlint": "^1.62.0",
    "prettier": "^3.8.3",
    "prettier-config-qiwi": "^3.0.1",
    "serve-static": "^2.2.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "ajv": "^8.20.0",
    "csv-parse": "^6.2.1",
    "fs-extra": "^11.3.4",
    "globby": "^16.2.0",
    "html-minifier-terser": "^7.2.0",
    "js-yaml": "^4.1.1",
    "meow": "^14.1.0",
    "nanoid": "^5.1.11",
    "slash": "^5.1.0",
    "temp-dir": "^3.0.0",
    "terser": "^5.46.2"
  },
  "keywords": [
    "radar",
    "tech-radar"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiwi/tech-radar.git"
  }
}
